{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "tilleuls-ortego-blocks/block-citation",
	"version": "0.1.0",
	"title": "Parole d'Expert",
	"category": "design",
	"icon": "editor-quote",
	"description": "Une mise en avant textuelle pour souligner une citation ou une valeur fondamentale du cabinet.",
	"keywords": ["quote", "citation", "témoignage", "avocat"],
	"supports": {
		"html": false,
		"align": ["wide", "full"]
	},
	"textdomain": "block-citation",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"attributes": {
		"citation": {
			"type": "string",
			"default": ""
		},
		"author": {
			"type": "string",
			"default": "Maître Ilazki Ortego Sampedro"
		}
	}
}
