{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "tilleuls-ortego-blocks/hero-page",
	"version": "0.1.0",
	"title": "En-tête secondaire de Page",
	"category": "design",
	"icon": "align-center",
	"description": "En-tête sobre pour les pages de services et d'informations.",
	"keywords": ["hero", "titre", "bannière", "page", "ortego"],
	"supports": {
		"html": false,
		"align": ["full"],
		"innerBlocks": true
	},
	"textdomain": "hero-page",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"attributes": {
		"title": {
			"type": "string",
			"default": "Mon Titre"
		},
		"description": {
			"type": "string",
			"default": ""
		}
	}
}
