{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "tilleuls-ortego-blocks/block-info-column",
	"version": "0.1.0",
	"title": "Encart d'Information",
	"category": "design",
	"description": "Un encart modulable pour souligner une information importante : aide juridictionnelle, tarifs, ou points de vigilance.",
	"keywords": ["info", "aide juridictionnelle", "tarif", "important", "ortego"],
	"supports": {
		"html": false
	},
	"textdomain": "block-info-column",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"attributes": {
		"infoItems": {
			"type": "array",
			"default": [],
			"items": {
				"type": "object",
				"default": {
					"icon": "fa-solid fa-gavel",
					"text": ""
				}
			}
		}
	}
}
