{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "tilleuls-ortego-blocks/block-cta",
	"version": "0.1.0",
	"title": "Appel à l'action (CTA)",
	"category": "design",
	"icon": "external",
	"description": "Une bannière pleine largeur avec un titre accrocheur et des boutons d'action (Téléphone, Email, RDV).",
	"keywords": ["contact", "bouton", "appel", "cta", "urgence"],
	"supports": {
		"html": false,
		"align": [
			"full"
		]
	},
	"textdomain": "block-cta",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"attributes": {
		"title": {
			"type": "string",
			"default": ""
		},
		"description": {
			"type": "string",
			"default": ""
		},
		"cta": {
			"type": "array",
			"default": [],
			"items": {
				"type": "object",
				"properties": {
					"text": { "type": "string", "default": "" },
					"linkType": { "type": "string", "default": "url" },
					"url": { "type": "string", "default": "" },
					"style": { "type": "string", "default": "primary" }
				}
			}
		}
	}
}
