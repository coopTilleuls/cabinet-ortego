{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "tilleuls-ortego-blocks/section-card",
	"version": "0.1.0",
	"title": "Philosophie & Atouts",
	"category": "design",
	"icon": "layout",
	"description": "Section composée de cartes descriptives pour mettre en avant vos engagements, votre philosophie ou vos compétences clés.",
	"keywords": ["philosophie", "carte", "valeurs", "atouts", "compétences", "ortego"],
	"supports": {
		"html": false,
		"align": ["wide", "full"],
		"innerBlocks": true
	},
	"textdomain": "section-card",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",

	"attributes": {
		"items": {
			"type": "array",
			"default": [],
			"items": {
				"type": "object",
				"default": {
					"icon": "fa-solid fa-gavel",
					"text": "",
					"description": ""
				}
			}
		},
		"style": {
			"type": "string",
			"default": ""
		}
	}
}
