{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "tilleuls-ortego-blocks/block-hero-homepage",
	"version": "0.1.0",
	"title": "En-tête page d'Accueil (Hero)",
	"category": "design",
	"icon": "cover-image",
	"description": "Bannière d'accueil principale avec image de fond, titre stylisé et boutons d'appel à l'action pour le premier contact.",
	"keywords": ["hero", "accueil", "bannière", "introduction", "home"],
	"supports": {
		"html": false,
		"align": ["wide", "full"]
	},
	"textdomain": "block-hero-homepage",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"attributes": {
		"surtitle": {
			"type": "string",
			"default": ""
		},
		"cta": {
			"type": "string",
			"default": "string"
		},
		"ctaBis": {
			"type": "string",
			"default": "string"
		}
	}

}
