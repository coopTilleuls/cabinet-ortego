{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "tilleuls-ortego-blocks/block-pricing",
	"version": "0.1.0",
	"title": "Grille Tarifaire",
	"category": "design",
	"icon": "admin-appearance",
	"description": "Section organisée pour présenter vos honoraires (Consultation, Forfait, Taux horaire) avec mise en avant optionnelle.",
	"keywords": ["prix", "honoraires", "grille", "devis", "comparatif", "ortego"],
	"supports": {
		"html": false,
		"align": ["full"],
		"innerBlocks": true
	},
	"textdomain": "block-pricing",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"attributes": {
		"pricingCards": {
			"type": "array",
			"default": [],
			"items": {
				"type": "object",
				"default": {
					"icon": "fa-solid fa-gavel",
					"text": ""
				}
			}
		}
	}
}
