{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "tilleuls-ortego-blocks/block-profile-homepage",
	"version": "0.1.0",
	"title": "Présentation de l'Avocat (page d'accueil)",
	"category": "design",
	"icon": "admin-users",
	"description": "Section portrait permettant d'afficher la biographie, une citation et les compétences linguistiques de l'avocat. A utiliser sur la page d'accueil.",
	"keywords": ["avocat", "profil", "biographie", "portrait", "langues", "ortego"],
	"example": {},
	"supports": {
		"html": false,
		"align": [
			"wide",
			"full"
		],
		"innerBlocks": true
	},
	"textdomain": "block-profile-homepage",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"attributes": {
		"imgId": {
			"type": "number",
			"default": 0
		},
		"imgUrl": {
			"type": "string",
			"default": ""
		},
		"quote": {
			"type": "string",
			"source": "html",
			"selector": ".about-quote"
		},
		"surtitle": {
			"type": "string",
			"default": ""
		},
		"buttonText": {
			"type": "string",
			"default": ""
		},
		"buttonLink": {
			"type": "string",
			"default": ""
		},
		"languages": {
			"type": "array",
			"default": [],
			"items": {
				"type": "object",
				"default": {
					"name": ""
				}
			}
		}
	}
}
