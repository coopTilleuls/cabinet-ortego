{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "tilleuls-ortego-blocks/block-column-with-img",
	"version": "0.1.0",
	"title": "Section Texte & Visuel",
	"category": "design",
	"icon": "columns",
	"description": "Une section en deux colonnes idéale pour présenter un domaine d'intervention avec un descriptif textuel et une illustration iconographique.",
	"keywords": ["service", "droit", "focus", "colonne", "expertise"],
	"supports": {
		"html": false,
		"align": [
			"full"
		]
	},
	"textdomain": "block-column-with-img",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"attributes": {
		"imgPosition": {
			"type": "string",
			"default": "left"
		},
		"icon": {
			"type": "string",
			"default": ""
		},
		"title": {
			"type": "string",
			"default": ""
		},
		"titleIcon": {
			"type": "string",
			"default": ""
		}
	}
}
